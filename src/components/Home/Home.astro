---
import portraitImg from "./assets/desktop.jpg";
import arrow from "./assets/arrow.svg";
---

<section id="home" class="container">
  <div class="content">
    <h1 id="title" hidden>Home</h1>
    <div class="portrait-container">
      <img class="portrait" src={portraitImg} alt="Carlos Frias Portrait" />
    </div>
    <div class="intro">
      <p class="name">
        I am {" "}
        <span class="semi">Carlos Frias</span>
      </p>
      <p class="job-title">front-end</p>
      <p class="job-sub">engineer</p>
    </div>
  </div>
  <div class="controls">
    <img src={arrow} alt="Arrow icon" />
  </div>
</section>

<style lang="scss">
  @use "../../styles/colors" as c;
  @use "../../styles/breakpoints" as br;
  @use "../../styles/spacing" as s;

  $transparent-black: rgba(0, 0, 0, 0.75);

  // -------------------------------------------------------
  // Container
  // -------------------------------------------------------
  .container {
    padding-top: var(--v-spacing-6);
    background-color: #000;
    background-image: url("./assets/bg.png");
    background-repeat: repeat;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    @include br.respond-to("small") {
      box-shadow: 0 0 250px rgb(0 0 0 / 90%) inset;
    }
  }

  // -------------------------------------------------------
  // Portrait
  // -------------------------------------------------------
  .portrait-container {
    width: 66%;
    background: c.$black;
    transform: rotate(-15deg) scale(0.8);
    margin-bottom: var(--v-spacing-3);

    @include br.respond-to("xs-landscape") {
      width: 33%;
      margin-bottom: 0;
      margin-right: 2rem;
    }
  }

  .portrait {
    width: 100%;
    clip-path: polygon(5% 0, 0 95%, 95% 100%, 100% 5%);
    transform: scale(1.2) rotate(15deg);
    display: block;
  }

  // -------------------------------------------------------
  // Content
  // -------------------------------------------------------
  .content {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;

    @include s.cap-width;

    @include br.respond-to("xs-landscape") {
      flex-direction: row;
    }

    @include br.respond-to("small") {
      margin-top: auto;
      margin-bottom: auto;
    }
  }

  // -------------------------------------------------------
  // Intro
  // -------------------------------------------------------
  .intro {
    line-height: 1;
    padding: 0 1.125rem;
    color: c.$white;
    display: flex;
    flex-direction: column;
  }

  .name {
    font-size: 1.82rem;
    color: c.$primary;
    margin: 0;
    margin-bottom: 1.125rem;
    line-height: 1;

    @include br.respond-to("medium") {
      margin-bottom: var(--v-spacing-2);
    }
  }

  .semi {
    font-weight: bold;
    color: c.$white;
    text-transform: uppercase;
  }

  .job-title {
    font-size: 3.272rem;
    font-weight: 900;
    margin-top: 0;
    margin-bottom: 0;
    text-transform: uppercase;
    line-height: 1;
    max-width: none !important;

    @include br.respond-to("small") {
      font-size: 4rem;
    }

    @include br.respond-to("medium") {
      font-size: 5rem;
    }
  }

  .job-sub {
    font-size: 1.618rem;
    max-width: 19rem;
    margin: 0;
    display: flex;
    align-items: center;

    @include br.respond-to("small") {
      max-width: 25rem;
    }

    @include br.respond-to("medium") {
      font-size: 2rem;
      max-width: 30rem;
    }
  }

  .job-sub::before {
    content: "";
    flex-grow: 2;
    display: block;
    height: 1px;
    background-color: c.$primary;
    margin-right: 1rem;
  }

  // -------------------------------------------------------
  // Controls
  // -------------------------------------------------------
  .controls {
    display: flex;
    justify-content: center;
  }
</style>
