---
// Component Imports
// import Tour from '../components/Tour.astro';
import Home from '../components/Home.astro';
// You can import components from any supported Framework here!

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width">

    <!-- START: meta tags -->
    <!-- Primary Meta Tags -->
    <meta name="title" content="Carlos Frias — Front-end Engineer">
    <meta name="description" content="I craft experiences with love, knowledge, and passion.">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cafrias.com">
    <meta property="og:title" content="Carlos Frias — Front-end Engineer">
    <meta property="og:description" content="I craft experiences with love, knowledge, and passion.">
    <meta property="og:image" content="https://i.ibb.co/tPnrPyT/desktop-bf0eaa8b.jpg">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://cafrias.com">
    <meta property="twitter:title" content="Carlos Frias — Front-end Engineer">
    <meta property="twitter:description" content="I craft experiences with love, knowledge, and passion.">
    <meta property="twitter:image" content="https://i.ibb.co/tPnrPyT/desktop-bf0eaa8b.jpg">
    <!-- END: meta tags -->

    <title>Carlos Frias | Front-end Engineer</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body>
    <main>
        <Home />
    </main>
</body>
</html>

<style global lang="scss">
@use '../styles/colors';
@use '../styles/typography';
@use '../styles/breakpoints';

@import url('https://fonts.googleapis.com/css2?family=Raleway:wght@400;700;800&display=swap');

:root {
    // 
    // Vertical Spacing
    // 
    --v-spacing-2: 2.023rem;
    --v-spacing-3: 2.945rem;
    --v-spacing-4: 3.272rem;
    --v-spacing-5: 4.765rem;
    --v-spacing-6: 5.295rem;
}

html {
    box-sizing: border-box;
    max-width: 100vw;
    background-color: #fff;
}


*, *:before, *:after {
    box-sizing: inherit;
}


body {
    margin: 0;
    color: colors.$black;
    max-width: 2400px;
    font-family: 'Raleway', sans-serif;
    overflow-x: hidden;
}

// HEADINGS ____________________________________________________________________
h1 {
    font-size: 5.295rem;
    text-transform: uppercase;
    font-weight: 900;
    line-height: 1;
    width: 100%;
    text-align: center;
}

h2 {
    font-size: 2.945rem;
    text-transform: uppercase;
    font-weight: 900;
    line-height: 1;
    text-align: center;
    color: colors.$secondary;
}

// TEXT ELEMENTS _______________________________________________________________
p, .text {
    line-height: 1.5;
    font-size: 1.125rem;
    max-width: typography.$max-readable;
}

strong {
    color: colors.$primary;
}

breakpoints.for-tablet-portrait-up {
    h1 {
        font-size: 7.71rem;
    }
  
    h2 {
        font-size: 4.765rem;
    }
}

breakpoints.for-desktop-up {
    h1 {
        font-size: 8.567rem;
    }
  
    h2 {
        font-size: 5.295rem;
    }
}
</style>
